#:import dp kivy.metrics.dp

<NavButton@Button>:
    size_hint: None, None
    size: dp(90), dp(68)
    background_normal: ''
    background_down: ''
    background_color: 1, 1, 1, 1
    color: 0.22, 0.26, 0.23, 1
    font_size: '12sp'
    text_size: self.width, self.height
    halign: 'center'
    valign: 'middle'
    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [18]

<StatCard@BoxLayout>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(120)
    padding: dp(16)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [20]

<PanelBox@BoxLayout>:
    orientation: 'vertical'
    size_hint_y: None
    height: self.minimum_height
    padding: dp(16)
    spacing: dp(12)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [20]

<DashboardScreen>:
    name: 'dashboard'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: app.background_color
            Rectangle:
                pos: self.pos
                size: self.size

        ScrollView:
            do_scroll_x: False
            bar_width: dp(6)
            scroll_type: ['bars', 'content']
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: dp(14), dp(18)
                spacing: dp(14)

                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(170)
                    padding: dp(18)
                    spacing: dp(10)
                    canvas.before:
                        Color:
                            rgba: app.primary_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [24]

                    Label:
                        text: 'UNTUNGIN'
                        color: 1, 1, 1, 1
                        font_size: '28sp'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Label:
                        text: 'Aplikasi Perhitungan Untung & Rugi Pedagang'
                        color: 1, 1, 1, 1
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                GridLayout:
                    cols: 1
                    spacing: dp(12)
                    size_hint_y: None
                    height: self.minimum_height

                    StatCard:
                        Label:
                            text: 'Total Omzet'
                            color: app.text_color
                            bold: True
                            font_size: '14sp'
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            id: omzet_value
                            text: 'Rp 0'
                            color: app.primary_color
                            bold: True
                            font_size: '24sp'
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    StatCard:
                        Label:
                            text: 'Total Pengeluaran'
                            color: app.text_color
                            bold: True
                            font_size: '14sp'
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            id: pengeluaran_value
                            text: 'Rp 0'
                            color: app.danger_text
                            bold: True
                            font_size: '24sp'
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    StatCard:
                        Label:
                            text: 'Net Profit'
                            color: app.text_color
                            bold: True
                            font_size: '14sp'
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            id: net_value
                            text: 'Rp 0'
                            color: app.success_text
                            bold: True
                            font_size: '24sp'
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                PanelBox:
                    Label:
                        text: 'Quick Calculate'
                        color: app.text_color
                        bold: True
                        font_size: '16sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    BoxLayout:
                        orientation: 'horizontal'
                        spacing: dp(10)
                        size_hint_y: None
                        height: dp(52)

                        Button:
                            text: 'UNTUNG'
                            background_normal: ''
                            background_color: app.primary_color
                            color: 1, 1, 1, 1
                            bold: True
                            on_release: app.set_quick_status('UNTUNG')

                        Button:
                            text: 'RUGI'
                            background_normal: ''
                            background_color: app.danger_text
                            color: 1, 1, 1, 1
                            bold: True
                            on_release: app.set_quick_status('RUGI')

                    Label:
                        id: quick_state_label
                        text: 'Pilih status untuk ringkasan'
                        color: app.muted_text
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                Label:
                    text: 'Ringkasan Transaksi'
                    color: app.text_color
                    bold: True
                    font_size: '16sp'
                    halign: 'left'
                    valign: 'middle'
                    size_hint_y: None
                    height: dp(28)
                    text_size: self.size

                GridLayout:
                    id: dashboard_transactions_list
                    cols: 1
                    spacing: dp(10)
                    size_hint_y: None
                    height: self.minimum_height

                Button:
                    text: 'View Details'
                    size_hint_y: None
                    height: dp(50)
                    background_normal: ''
                    background_color: app.primary_color
                    color: 1, 1, 1, 1
                    bold: True
                    on_release: app.switch_screen('riwayat')

<RingkasanButton@Button>:
    size_hint_y: None
    height: dp(50)
    background_normal: ''
    background_color: app.primary_color
    color: 1, 1, 1, 1
    bold: True

<HitungBaruScreen>:
    name: 'hitung_baru'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: app.background_color
            Rectangle:
                pos: self.pos
                size: self.size

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: dp(14), dp(18)
                spacing: dp(14)

                PanelBox:
                    Label:
                        text: 'Hitung Baru'
                        color: app.text_color
                        bold: True
                        font_size: '18sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Label:
                        text: 'Nama Produk'
                        color: app.text_color
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    TextInput:
                        id: product_input
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        background_normal: ''
                        background_color: 1, 1, 1, 1
                        foreground_color: app.text_color
                        padding: dp(14), dp(12)

                    Label:
                        text: 'Kategori'
                        color: app.text_color
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    TextInput:
                        id: category_input
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        background_normal: ''
                        background_color: 1, 1, 1, 1
                        foreground_color: app.text_color
                        padding: dp(14), dp(12)

                    Label:
                        text: 'Harga Modal'
                        color: app.text_color
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    TextInput:
                        id: modal_input
                        multiline: False
                        input_filter: 'float'
                        size_hint_y: None
                        height: dp(48)
                        background_normal: ''
                        background_color: 1, 1, 1, 1
                        foreground_color: app.text_color
                        padding: dp(14), dp(12)

                    Label:
                        text: 'Harga Jual'
                        color: app.text_color
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    TextInput:
                        id: price_input
                        multiline: False
                        input_filter: 'float'
                        size_hint_y: None
                        height: dp(48)
                        background_normal: ''
                        background_color: 1, 1, 1, 1
                        foreground_color: app.text_color
                        padding: dp(14), dp(12)

                    Label:
                        text: 'Jumlah Unit'
                        color: app.text_color
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    TextInput:
                        id: qty_input
                        multiline: False
                        input_filter: 'int'
                        size_hint_y: None
                        height: dp(48)
                        background_normal: ''
                        background_color: 1, 1, 1, 1
                        foreground_color: app.text_color
                        padding: dp(14), dp(12)

                    Button:
                        text: 'HITUNG SEKARANG'
                        size_hint_y: None
                        height: dp(52)
                        background_normal: ''
                        background_color: app.primary_color
                        color: 1, 1, 1, 1
                        bold: True
                        on_release: app.on_calculate()

                PanelBox:
                    Label:
                        text: 'Hasil Perhitungan'
                        color: app.text_color
                        bold: True
                        font_size: '18sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Label:
                        id: status_result
                        text: 'Status: -'
                        color: app.text_color
                        font_size: '15sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Label:
                        id: total_modal_result
                        text: 'Total Modal: Rp 0'
                        color: app.text_color
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Label:
                        id: total_jual_result
                        text: 'Total Jual: Rp 0'
                        color: app.text_color
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Label:
                        id: untung_result
                        text: 'Untung/Rugi: Rp 0'
                        color: app.success_text
                        bold: True
                        font_size: '15sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Label:
                        id: margin_result
                        text: 'Margin: 0%'
                        color: app.muted_text
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

                    Button:
                        id: save_btn
                        text: 'Simpan Transaksi'
                        size_hint_y: None
                        height: dp(52)
                        background_normal: ''
                        background_color: app.accent_color
                        color: 1, 1, 1, 1
                        bold: True
                        disabled: True
                        on_release: app.on_save_transaction()

                    Label:
                        id: feedback_label
                        text: 'Masukkan data produk untuk menghitung.'
                        color: app.muted_text
                        font_size: '14sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

<RiwayatScreen>:
    name: 'riwayat'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: app.background_color
            Rectangle:
                pos: self.pos
                size: self.size

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: dp(14), dp(18)
                spacing: dp(14)

                Label:
                    text: 'Riwayat Transaksi'
                    color: app.text_color
                    bold: True
                    font_size: '18sp'
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

                BoxLayout:
                    spacing: dp(10)
                    size_hint_y: None
                    height: dp(50)

                    Button:
                        text: 'Ekspor CSV'
                        background_normal: ''
                        background_color: app.primary_color
                        color: 1, 1, 1, 1
                        bold: True
                        on_release: app.on_export_csv()

                    Button:
                        text: 'Hapus Semua'
                        background_normal: ''
                        background_color: app.danger_text
                        color: 1, 1, 1, 1
                        bold: True
                        on_release: app.on_clear_transactions()

                GridLayout:
                    id: history_grid
                    cols: 1
                    spacing: dp(10)
                    size_hint_y: None
                    height: self.minimum_height

<LaporanScreen>:
    name: 'laporan'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: app.background_color
            Rectangle:
                pos: self.pos
                size: self.size

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: dp(14), dp(18)
                spacing: dp(14)

                Label:
                    text: 'Laporan Harian'
                    color: app.text_color
                    bold: True
                    font_size: '18sp'
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

                GridLayout:
                    id: report_grid
                    cols: 1
                    spacing: dp(10)
                    size_hint_y: None
                    height: self.minimum_height

BoxLayout:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: app.background_color
        Rectangle:
            pos: self.pos
            size: self.size

    ScreenManager:
        id: screen_manager

        DashboardScreen:
        HitungBaruScreen:
        RiwayatScreen:
        LaporanScreen:

    BoxLayout:
        size_hint_y: None
        height: dp(84)
        padding: dp(8)
        spacing: dp(8)
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        NavButton:
            id: dashboard_btn
            text: '🏠\nDashboard'
            background_color: app.accent_color
            color: 1, 1, 1, 1
            on_release: app.switch_screen('dashboard')

        NavButton:
            id: hitung_btn
            text: '🧾\nHitung Baru'
            on_release: app.switch_screen('hitung_baru')

        NavButton:
            id: riwayat_btn
            text: '📜\nRiwayat'
            on_release: app.switch_screen('riwayat')

        NavButton:
            id: laporan_btn
            text: '📊\nLaporan'
            on_release: app.switch_screen('laporan')
